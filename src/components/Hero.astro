---
import { Image } from 'astro:assets'
import profilePicture from '../assets/profile-img.jpeg'
---

<section class="flex min-h-[calc(100vh-65px)] items-center overflow-x-hidden px-6 py-20" id="about">
  <div class="container grid grid-cols-1 gap-16 md:grid-cols-2 md:items-center">
    <div>
      <p class="reveal reveal-up mb-2 text-lg font-medium text-accent-light">Hi there, I'm</p>
      <h1 class="hero-name-gradient reveal reveal-up mb-2 font-black leading-tight" style="font-size: clamp(2.4rem, 6vw, 4rem); --reveal-delay: 140ms;">Yago Gefaell</h1>
      <h2 class="reveal reveal-up mb-6 font-mono font-medium text-text-muted" style="font-size: clamp(1.1rem, 2.5vw, 1.5rem); --reveal-delay: 260ms;">Full Stack Developer</h2>
      <p class="reveal reveal-up mb-9 max-w-xl leading-relaxed text-text-muted" style="--reveal-delay: 420ms;">
        I build modern web applications with a passion for clean code and great user experiences.
        I enjoy working across the full stack — from interactive frontends with React and Vue
        to robust backends with Java &amp; Spring Boot, all packaged with Docker.
      </p>
      <div class="reveal reveal-up flex flex-wrap gap-4" style="--reveal-delay: 560ms;">
        <a href="#projects" class="btn btn-primary font-mono">View Projects</a>
        <a href="#contact" class="btn btn-outline font-mono">Get in Touch</a>
      </div>
    </div>
    <div class="reveal reveal-up relative flex items-center justify-center md:h-96" style="--reveal-delay: 220ms;" aria-hidden="true">
      <div class="avatar-ring">
        <Image
          src={profilePicture}
          alt="Yago Gefaell picture"
          width={320}
          height={320}
          loading="eager"
        />
      </div>
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
    </div>
  </div>
</section>
