---
interface Project {
  title: string;
  description: string;
  tags: string[];
  repoUrl?: string;
  liveUrl?: string;
}

const projects: Project[] = [
  {
    title: 'Fisioterapia Gefaell Web',
    description:
      'A modern, SEO-optimized web platform for a physiotherapy clinic built with a focus on speed and performance.',
    tags: ['Astro', 'TypeScript', 'Tailwind'],
    repoUrl: 'https://github.com/YagoGefaell/fisioterapia-gefaell-web',
  },
  {
    title: 'Teis Motor',
    description:
      'Management platform for a dealership/workshop built with Vue.js. Enables vehicle inventory tracking and customer management.',
    tags: ['Vue', 'JavaScript', 'CSS', 'Node.js'],
    repoUrl: 'https://github.com/YagoGefaell/teis-motor',
  },
  {
    title: 'BlackJack Pygame',
    description:
      'Implementation of the classic BlackJack card game using the Pygame library. Includes complete game logic and a graphical interface.',
    tags: ['Python', 'Pygame'],
    repoUrl: 'https://github.com/YagoGefaell/blackJack-pygame',
  },
  {
    title: 'MTG API',
    description:
      'REST API inspired by Magic: The Gathering. Provides endpoints to query card information and manage personal collections.',
    tags: ['Java', 'Spring Boot', 'REST API', 'MySql'],
    repoUrl: 'https://github.com/YagoGefaell/mtg-api',
  },
  {
    title: 'Portfolio Website',
    description:
      'Personal website built with Astro and Tailwind CSS. Includes dynamic sections for projects and experience, optimized for performance and SEO.',
    tags: ['Astro', 'TypeScript', 'Tailwind'],
    repoUrl: 'https://github.com/YagoGefaell/portfolio',
  },
  {
    title: 'Asaltamontes',
    description:
      'Project focused on managing and visualizing routes or events (depending on the current state of the repository), using JavaScript for client-side logic.',
    tags: ['Spring', 'React', 'WebSocket', 'Authentication'],
    repoUrl: 'https://github.com/YagoGefaell/asaltamontes',
  },
];
---

<section id="projects">
  <div class="container">
    <h2 class="section-title">Projects</h2>
    <p class="section-subtitle">A selection of things I've built</p>
    <ul class="projects-grid">
      {
        projects.map((project) => (
          <li
            class="project-card"
            data-repo-url={project.repoUrl}
            tabindex={project.repoUrl ? '0' : undefined}
            role={project.repoUrl ? 'link' : undefined}
            aria-label={project.repoUrl ? `View ${project.title} repository` : undefined}
          >
            <div class="card-header">
              <svg class="folder-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3 7C3 5.9 3.9 5 5 5H9.59C9.85 5 10.1 5.1 10.29 5.29L11.71 6.71C11.9 6.9 12.15 7 12.41 7H19C20.1 7 21 7.9 21 9V17C21 18.1 20.1 19 19 19H5C3.9 19 3 18.1 3 17V7Z" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              </svg>
              <div class="card-links">
                {project.repoUrl && (
                  <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" aria-label="View repository">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                    </svg>
                  </a>
                )}
                {project.liveUrl && (
                  <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" aria-label="View live demo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-description">{project.description}</p>
            <ul class="project-tags">
              {project.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  const openProjectRepo = (url: string) => {
    window.open(url, '_blank', 'noopener,noreferrer');
  };

  const clickableCards = document.querySelectorAll<HTMLElement>('.project-card[data-repo-url]');

  clickableCards.forEach((card) => {
    const repoUrl = card.getAttribute('data-repo-url');

    if (!repoUrl) return;

    card.addEventListener('click', (event) => {
      if (event.target instanceof Element && event.target.closest('a')) return;
      openProjectRepo(repoUrl);
    });

    card.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      openProjectRepo(repoUrl);
    });
  });
</script>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .project-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .project-card[data-repo-url] {
    cursor: pointer;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 32px rgba(124, 106, 247, 0.15);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .folder-icon {
    width: 38px;
    height: 38px;
    color: var(--color-accent);
  }

  .card-links {
    display: flex;
    gap: 14px;
  }

  .card-links a {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
  }

  .card-links a:hover {
    color: var(--color-text);
  }

  .card-links svg {
    width: 20px;
    height: 20px;
  }

  .project-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .project-description {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
  }

  .tag {
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-mono);
    color: var(--color-accent-light);
    background-color: rgba(124, 106, 247, 0.1);
    padding: 3px 10px;
    border-radius: 20px;
    border: 1px solid rgba(124, 106, 247, 0.2);
  }
</style>
