---
const year = new Date().getFullYear();
---

<footer class="border-t border-border px-6 py-7">
  <div class="container flex flex-wrap items-center justify-between gap-4 md:flex-nowrap">
    <a href="/" class="font-mono text-xl font-black text-text">
      <span class="text-accent">&lt;</span>YG<span class="text-accent">/&gt;</span>
    </a>
    <p class="text-sm text-text-muted">
      &copy; {year} Yago Gefaell. Built with
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-accent-light hover:text-accent">Astro</a>.
    </p>
    <a href="#top" class="flex h-9 w-9 items-center justify-center rounded-sm border border-border bg-surface text-text-muted transition-all duration-200 hover:border-accent hover:bg-surface-2 hover:text-text" aria-label="Back to top">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="h-4.5 w-4.5"
      >
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </a>
  </div>
</footer>
